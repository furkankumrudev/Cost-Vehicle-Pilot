# Cost Vehicle Pilot local settings

# Runtime database: sqlite or postgres. SQLite is the local default.
DB_TYPE=sqlite
SQLITE_DB_PATH=data/runtime/vehicle_listings.sqlite3

# PostgreSQL can be enabled later.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cost_vehicle_pilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
